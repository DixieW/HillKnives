# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose to browser

# ── Auth.js (OAuth2) ──────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
AUTH_SECRET=your-random-secret-here

# GitHub OAuth App — create at: https://github.com/settings/developers
# Callback URL: https://yourdomain.com/auth/callback/github
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# ── hCaptcha ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.hcaptcha.com
# The SITE_KEY goes in the frontend; the SECRET goes here (server-side only)
HCAPTCHA_SECRET=your-hcaptcha-secret-key

# ── Copy this file to .env and fill in your values ───────────────────────────
# NEVER commit .env to git — it is already in .gitignore
